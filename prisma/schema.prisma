generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  sessions  Session[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  expiresAt    DateTime
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  contact       String?
  favoriteDrink String?
  interestTags  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PromoCampaign {
  id          String   @id @default(cuid())
  theme       String
  segment     String
  whyNow      String?
  message     String
  timeWindow  String?
  customerCount Int?
  createdAt   DateTime @default(now())
}
