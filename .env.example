# Supabase: Project Settings -> Database -> Connection string (URI). Ganti [YOUR-PASSWORD] dengan password database.
# Pakai "Transaction" (port 6543) untuk Vercel/serverless, atau "Session" (port 5432) untuk migrasi.
DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
OPENROUTER_API_KEY=""
GROQ_API_KEY=""
GOOGLE_AI_API_KEY=""
AI_PROVIDER=openrouter
